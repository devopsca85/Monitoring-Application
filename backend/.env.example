# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=monitoring_db

# Security
SECRET_KEY=your-secret-key-change-in-production
CREDENTIAL_ENCRYPTION_KEY=your-32-byte-encryption-key!!

# Azure Key Vault
AZURE_KEY_VAULT_URL=https://your-vault.vault.azure.net/

# Azure Communication Services (Email)
AZURE_COMM_CONNECTION_STRING=endpoint=https://your-comm.communication.azure.com/;accesskey=...
AZURE_COMM_SENDER_EMAIL=DoNotReply@your-domain.com

# Teams Webhook
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/...

# Azure Application Insights
APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=...

# Monitoring Engine
MONITORING_ENGINE_URL=http://monitoring-engine:8001
