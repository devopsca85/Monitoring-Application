# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=monitoring_db

# Security
SECRET_KEY=your-secret-key-change-in-production
CREDENTIAL_ENCRYPTION_KEY=your-32-byte-encryption-key!!

# Azure Key Vault (optional)
AZURE_KEY_VAULT_URL=https://your-vault.vault.azure.net/

# Azure Application Insights (optional)
APPINSIGHTS_CONNECTION_STRING=InstrumentationKey=...

# Monitoring Engine URL
MONITORING_ENGINE_URL=http://monitoring-engine:8001

# Note: SMTP and Teams webhook settings are managed via Admin > Settings in the UI
